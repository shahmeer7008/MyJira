@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
    Layout = null; // Ensure this matches your layout file
}
<html>
    <head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    </head>
<body>
<!-- Main Container -->
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar Column -->
        <div class="col-md-2 sidebar">
            <partial name="_Sidebar" /> <!-- Your sidebar partial -->
        </div>

        <!-- Main Content Column -->
        <div class="col-md-10 content-area" style="background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D') no-repeat center center fixed; background-size: cover; min-height: 100vh;">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-6 col-md-8">
                        <!-- Logout Card -->
                        <div class="card shadow-lg border-0" style="background-color: rgba(255, 255, 255, 0.93);">
                            <div class="card-body p-5">
                                <div class="text-center mb-4">
                                    <h2 class="fw-bold text-dark">@ViewData["Title"]</h2>
                                </div>

                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                                        <div class="d-grid gap-2">
                                            <button type="submit" class="btn btn-primary btn-lg py-3">
                                                <i class="bi bi-box-arrow-right me-2"></i> Confirm Logout
                                            </button>
                                        </div>
                                    </form>
                                }
                                else
                                {
                                    <div class="text-center">
                                        <div class="mb-4">
                                            <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                                        </div>
                                        <p class="lead text-muted mb-4">You have successfully logged out of the application.</p>
                                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg px-4">
                                            <i class="bi bi-box-arrow-in-right me-2"></i> Return to Login
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
<style>
    /* Consistent with admin dashboard styles */
    .sidebar {
        background-color: #2c3e50;
        min-height: 100vh;
        padding: 0;
        box-shadow: 3px 0 10px rgba(0, 0, 0, 0.1);
    }

    .card {
        border-radius: 10px;
        overflow: hidden;
    }

    .btn-danger {
        background-color: #e74c3c;
        border-color: #e74c3c;
        transition: all 0.3s;
    }

        .btn-danger:hover {
            background-color: #c0392b;
            border-color: #c0392b;
            transform: translateY(-2px);
        }

    .btn-primary {
        background-color: #3498db;
        border-color: #3498db;
        transition: all 0.3s;
    }

        .btn-primary:hover {
            background-color: #2980b9;
            border-color: #2980b9;
            transform: translateY(-2px);
        }
</style>