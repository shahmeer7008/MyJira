@{
    Layout = null;
}
@{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>Project Details</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/dashboard.css" />
        <style>
            /* Sidebar Styling */

            body {
                display: flex;
                background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
                background-size: cover;
                background-position: center;
                height: 100vh;
                margin: 0;
            }

            .main-content {
                margin-left: 150px;
            }


            /* Toggle Button */
            .toggle-btn {
                position: absolute;
                top: 10px;
                left: 260px;
                background: #007bff;
                color: white;
                border: none;
                padding: 8px 12px;
                cursor: pointer;
                transition: left 0.3s ease-in-out;
            }

            .collapsed .toggle-btn {
                left: 70px;
            }

            .heading {
                color: white;
            }
        </style>
    </head>
    <body class="bg-light">

        <!-- Sidebar -->
        <div class="app-wrapper">
            @Html.Partial("_ManagerSidebar")

            <main class="app-main">

                <!-- Main Content -->
                <div class="container mt-5 main-content" id="mainContent">
                    <div class="heading">
                        <h2 class="text-center mb-4">Project Details</h2>
                    </div>

                    <!-- Project Overview -->
                    <div class="row">
                        <div class="col-md-4">
                            <div class="card text-white bg-primary mb-3">
                                <div class="card-header">Project ID</div>
                                <div class="card-body">
                                    <h5 class="card-title">PJT-101</h5>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card text-white bg-success mb-3">
                                <div class="card-header">Project Name</div>
                                <div class="card-body">
                                    <h5 class="card-title">Website Revamp</h5>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card text-white bg-warning mb-3">
                                <div class="card-header">Status</div>
                                <div class="card-body">
                                    <h5 class="card-title">In Progress</h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Project Members Table -->
                    <div class="card mt-4">
                        <div class="card-header bg-info text-white">
                            Team Members
                        </div>
                        <div class="card-body">
                            <table class="table table-bordered table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Member ID</th>
                                        <th>Name</th>
                                        <th>Role</th>
                                        <th>Email</th>
                                    </tr>
                                </thead>
                                <tbody class="table-dark" style="color:white">
                                    <tr>
                                        <td>M001</td>
                                        <td>Alice Johnson</td>
                                        <td>Project Manager</td>
                                        <td>alice@example.com</td>
                                    </tr>
                                    <tr>
                                        <td>M002</td>
                                        <td>Bob Smith</td>
                                        <td>Developer</td>
                                        <td>bob@example.com</td>
                                    </tr>
                                    <tr>
                                        <td>M003</td>
                                        <td>Charlie Brown</td>
                                        <td>Designer</td>
                                        <td>charlie@example.com</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Issues Resolved Section -->
                    <div class="card mt-4">
                        <div class="card-header bg-danger text-white">
                            Issues Resolved
                        </div>
                        <div class="card-body bg-primary" style="color:white">
                            <ul class="list-group ">
                                <li class="list-group-item text-white" style="background-color:saddlebrown">Bug #101: Fixed UI alignment</li>
                                <li class="list-group-item text-white" style="background-color:saddlebrown">Bug #102: Resolved login issue</li>
                                <li class="list-group-item text-white" style="background-color:saddlebrown">Bug #103: Optimized page speed</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </main>
        </div>
        <script>
            document.getElementById("toggleBtn").addEventListener("click", function () {
                document.getElementById("sidebar").classList.toggle("collapsed");
                document.getElementById("mainContent").classList.toggle("collapsed");
            });
        </script>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
    </html>

}
