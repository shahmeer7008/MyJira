

@{
    Layout = null;
}
@{
    int ProjectCompleted = ViewBag.ProjectCompleted;
    int IssuesResolved = ViewBag.IssuesResolved;
    int AddedIssues = ViewBag.AddedIssues;
    int TeamPerformance = ViewBag.TeamPerformance;
    var IssuesResolvedWeekly = ViewBag.IssuesResolvedWeekly;
    var TeamPerformanceData = ViewBag.TeamPerformanceData;
    var TeamMembers = ViewBag.TeamMembers;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <title>Project Manager Dashboard</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />

    <link rel="stylesheet" href="/css/dashboard.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.10.1/styles/overlayscrollbars.min.css"
          integrity="sha256-tZHrRjVqNSRyWg2wbppGnT833E/Ys0DHWGwT04GiqQg="
          crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css?family=Raleway:400,300,600,800,900" rel="stylesheet" type="text/css">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          integrity="sha256-9kPW/n5nn53j4WMRYAxe9c1rCY96Oogo/MKSVdKzPmI="
          crossorigin="anonymous" />
    <link rel="stylesheet" href="/css/dashboard.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/apexcharts@3.37.1/dist/apexcharts.css"
          integrity="sha256-4MX+61mt9NVvvuPjUWdUdyfZfxSB1/Rf9WtqRHgG5S0="
          crossorigin="anonymous" />
    <!-- jsvectormap -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/jsvectormap@1.5.3/dist/css/jsvectormap.min.css"
          integrity="sha256-+uGLJmmTKOqBr+2E6KDYs/NRsHxSkONXFHUL0fy2O/4="
          crossorigin="anonymous" />

    <style>
        /* General Card Styling */
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            overflow-x: hidden;
            background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
            background-attachment: fixed;
            background-size: cover;
            background-position: center;
        }
        .small-box {
            text-align: center;
            padding: 20px;
            border-radius: 10px;
            color: white;
        }

        /* Centered SVG Circle */
        .progress-container {
            position: relative;
            width: 120px;
            height: 120px;
            margin: 0 auto;
        }

        /* SVG Styling */
        .progress-svg {
            transform: rotate(-90deg); /* Rotates so progress starts from top */
        }

        /* Background Circle */
        .circle-bg {
            fill: none;
            stroke: rgba(255, 255, 255, 0.2); /* Light background stroke */
            stroke-width: 10;
        }

        /* Progress Bar Stroke */
        .circle-progress {
            fill: none;
            stroke: white; /* White progress stroke */
            stroke-width: 10;
            stroke-linecap: round;
            stroke-dasharray: 314; /* Full circle circumference (2 * π * 50) */
            stroke-dashoffset: 314; /* Initially hidden */
            transition: stroke-dashoffset 1.5s ease-in-out;
        }

        /* Percentage Text */
        .progress-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-weight: bold;
            font-size: 22px;
            color: white;
        }

        .metrics-carousel {
            margin: 0 auto 20px auto;
            width: 100%;
            height: 300px;
            overflow: hidden;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

            .metrics-carousel .carousel-item img {
                width: 100%;
                height: 300px;
                object-fit: cover;
                object-position: center;
            }

        .carousel-caption {
            background-color: rgba(0, 0, 0, 0.6);
            border-radius: 5px;
            padding: 10px 15px;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: 80%;
            text-align: center;
        }

        .carousel-control-prev,
        .carousel-control-next {
            width: 5%;
            background-color: rgba(0, 0, 0, 0.3);
            border-radius: 5px;
        }

        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            width: 2rem;
            height: 2rem;
        }

        .chart-container {
        width: 100%;
        height: 100%;
        min-height: 300px;
    }
    
    /* Card Styling */
    .card {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    
    .card-header {
        border-bottom: 1px solid rgba(255,255,255,0.2);
        padding: 15px 20px;
    }
    
    .card-body {
        padding: 20px;
        position: relative;
    }
    
    /* Specific Chart Adjustments */
    #project-completed-chart .apexcharts-text,
    #project-completed-chart .apexcharts-datalabel {
        fill: #fff !important;
    }
    
    /* Responsive Adjustments */
    @@media (max-width: 768px) {
        .card {
            height: auto !important;
        }
    }

    </style>
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <!--begin::App Wrapper-->
    <div class="app-wrapper">
        <div class="d-flex justify-content-center" style="color:white"> <h3 class="mb-0 text-center">Project Manager Dashboard</h3></div>

        <!--begin::Header-->
        <!--end::Header-->
        <!--begin::Sidebar-->
        @Html.Partial("_ManagerSidebar");
        <div class="content">
        <main class="app-main">
            
            <div class="app-content-header mb-3">
                <!--begin::Container-->
                <div class="container mt-4">
                    


                    <div id="metricsCarousel" class="carousel slide metrics-carousel" data-bs-ride="carousel"
                         data-bs-interval="3000">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img src="https://images.unsplash.com/photo-1579389083078-4e7018379f7e?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80"
                                     class="d-block w-100" alt="Team Collaboration">
                                <div class="carousel-caption">
                                    <h5>Team Collaboration</h5>
                                    <p>Brainstorming ideas for better project outcomes</p>
                                </div>
                            </div>
                            <div class="carousel-item">
                                <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80"
                                     class="d-block w-100" alt="Project Management">
                                <div class="carousel-caption">
                                    <h5>Project Tracking</h5>
                                    <p>Monitoring progress and updating milestones</p>
                                </div>
                            </div>
                            <div class="carousel-item">
                                <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80"
                                     class="d-block w-100" alt="Planning">
                                <div class="carousel-caption">
                                    <h5>Strategic Planning</h5>
                                    <p>Creating effective business plans for success</p>
                                </div>
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#metricsCarousel"
                                data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#metricsCarousel"
                                data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>

      


                    <!-- /.row (main row) -->
                </div>
                <!--end::Container-->
            </div>
            <!--end::App Content-->
        </main>
      </div>
    </div>
   
    <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.10.1/browser/overlayscrollbars.browser.es6.min.js"
            integrity="sha256-dghWARbRe2eLlIJ56wNB+b760ywulqK3DzZYEpsg2fQ="
            crossorigin="anonymous"></script>
   
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"
            integrity="sha384-0pUGZvbkm6XF6gxjEnlmuGrJXVbNuzT9qBBavbLwCsOGabYfZo0T0to5eqruptLy"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.37.1/dist/apexcharts.min.js"
            integrity="sha256-+vh8GkaU7C9/wbSLIcwq82tQ2wTf44aOHA8HlBMwRI8=" crossorigin="anonymous"></script>
    <script>
        const SELECTOR_SIDEBAR_WRAPPER = '.sidebar-wrapper';
        const Default = {
            scrollbarTheme: 'os-theme-light',
            scrollbarAutoHide: 'leave',
            scrollbarClickScroll: true,
        };
        document.addEventListener('DOMContentLoaded', function () {
            const sidebarWrapper = document.querySelector(SELECTOR_SIDEBAR_WRAPPER);
            if (sidebarWrapper && typeof OverlayScrollbarsGlobal?.OverlayScrollbars !== 'undefined') {
                OverlayScrollbarsGlobal.OverlayScrollbars(sidebarWrapper, {
                    scrollbars: {
                        theme: Default.scrollbarTheme,
                        autoHide: Default.scrollbarAutoHide,
                        clickScroll: Default.scrollbarClickScroll,
                    },
                });
            }
        });
    </script>

   <script>
    document.addEventListener('DOMContentLoaded', function () {
        // Set default data if ViewBag values are null
        const issuesResolvedWeekly = @Html.Raw(IssuesResolvedWeekly != null ? Json.Serialize(IssuesResolvedWeekly) : "[0,0,0,0,0,0,0]");
        const teamPerformanceData = @Html.Raw(TeamPerformanceData != null ? Json.Serialize(TeamPerformanceData) : "[0,0,0,0,0]");
        const teamMembers = @Html.Raw(TeamMembers != null ? Json.Serialize(TeamMembers) : "['Team 1','Team 2','Team 3','Team 4','Team 5']");

        // Enhanced Project Completed Chart (Radial Bar with Track)
            const projectProgressOptions = {
                series: [{
                    name: 'Progress',
                    data: [{
                        x: 'Tasks Completed',
                        y: @ProjectCompleted,
                        goals: [
                            {
                                name: 'Target',
                                value: 100,
                                strokeHeight: 5,
                                strokeColor: '#775DD0'
                            }
                        ]
                    },
                    {
                        x: 'Issues Resolved',
                        y: @IssuesResolved,
                        goals: [
                            {
                                name: 'Target',
                                value: @AddedIssues,
                                strokeHeight: 5,
                                strokeColor: '#775DD0'
                            }
                        ]
                    }]
                }],
                chart: {
                    type: 'bar',
                    height: '100%',
                    background: 'transparent',
                    foreColor: '#fff'
                },
                colors: ['#28a745', '#17a2b8'],
                plotOptions: {
                    bar: {
                        horizontal: true,
                        barHeight: '60%',
                        borderRadius: 4,
                        distributed: false
                    }
                },
                dataLabels: {
                    enabled: true,
                    formatter: function (val) {
                        return val + '%';
                    },
                    style: {
                        colors: ['#fff'],
                        fontSize: '12px',
                        fontWeight: 'bold'
                    }
                },
                xaxis: {
                    categories: ['Tasks Completed', 'Issues Resolved'],
                    labels: {
                        style: {
                            colors: '#fff',
                            fontSize: '14px'
                        }
                    },
                    axisBorder: {
                        show: true,
                        color: 'rgba(255, 255, 255, 0.1)'
                    },
                    axisTicks: {
                        show: true,
                        color: 'rgba(255, 255, 255, 0.1)'
                    }
                },
                yaxis: {
                    show: false
                },
                grid: {
                    borderColor: 'rgba(255, 255, 255, 0.1)',
                    strokeDashArray: 4
                },
                tooltip: {
                    theme: 'dark',
                    y: {
                        formatter: function (val) {
                            return val + '%';
                        }
                    }
                },
                annotations: {
                    xaxis: [{
                        x: 100,
                        borderColor: '#775DD0',
                        label: {
                            borderColor: '#775DD0',
                            style: {
                                color: '#fff',
                                background: '#775DD0'
                            },
                            text: 'Target'
                        }
                    }]
                },
                responsive: [{
                    breakpoint: 768,
                    options: {
                        chart: {
                            height: 300
                        },
                        plotOptions: {
                            bar: {
                                barHeight: '50%'
                            }
                        }
                    }
                }]
            };

            const projectProgressChart = new ApexCharts(
                document.querySelector("#project-completed-chart"),
                projectProgressOptions
            );
            projectProgressChart.render();

        // Issues Resolved Chart (Column Chart)
        const issuesResolvedOptions = {
            series: [{
                name: 'Resolved',
                data: issuesResolvedWeekly
            }],
            chart: {
                type: 'bar',
                height: '100%',
                foreColor: '#fff',
                background: 'transparent',
                toolbar: {
                    show: false
                }
            },
            colors: ['red'],
            plotOptions: {
                bar: {
                    borderRadius: 4,
                    horizontal: false,
                    columnWidth: '55%',
                }
            },
            dataLabels: {
                enabled: false
            },
            stroke: {
                show: true,
                width: 2,
                colors: ['transparent']
            },
            xaxis: {
                categories: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                labels: { 
                    style: { 
                        colors: '#fff',
                        fontSize: '12px'
                    } 
                },
                axisBorder: {
                    show: true,
                    color: 'rgba(255, 255, 255, 0.1)'
                },
                axisTicks: {
                    show: true,
                    color: 'rgba(255, 255, 255, 0.1)'
                }
            },
            yaxis: {
                labels: { 
                    style: { 
                        colors: '#fff',
                        fontSize: '12px'
                    } 
                }
            },
            grid: {
                borderColor: 'rgba(255, 255, 255, 0.1)',
                strokeDashArray: 4,
                xaxis: {
                    lines: {
                        show: true
                    }
                },
                yaxis: {
                    lines: {
                        show: true
                    }
                }
            },
            tooltip: {
                theme: 'dark',
                y: {
                    formatter: function (val) {
                        return val + " issues";
                    }
                }
            }
        };

        const issuesResolvedChart = new ApexCharts(
            document.querySelector("#issues-resolved-chart"),
            issuesResolvedOptions
        );
        issuesResolvedChart.render();

        // Teams Performance Chart (Bar Chart)
        const teamsPerformanceOptions = {
            series: [{
                name: 'Performance',
                data: teamPerformanceData
            }],
            chart: {
                type: 'bar',
                height: '100%',
                foreColor: '#fff',
                background: 'transparent',
                toolbar: {
                    show: false
                }
            },
            colors: ['red'],
            plotOptions: {
                bar: {
                    borderRadius: 4,
                    horizontal: true,
                }
            },
            dataLabels: {
                enabled: true,
                style: {
                    colors: ['#000'],
                    fontSize: '12px'
                },
                formatter: function(val) {
                    return val + '%';
                },
                offsetX: 10
            },
            xaxis: {
                categories: teamMembers,
                labels: { 
                    style: { 
                        colors: '#fff',
                        fontSize: '12px'
                    } 
                },
                axisBorder: {
                    show: true,
                    color: 'rgba(255, 255, 255, 0.1)'
                }
            },
            yaxis: {
                labels: { 
                    style: { 
                        colors: '#fff',
                        fontSize: '12px'
                    } 
                }
            },
            grid: {
                borderColor: 'rgba(255, 255, 255, 0.1)',
                strokeDashArray: 4,
                xaxis: {
                    lines: {
                        show: true
                    }
                },
                yaxis: {
                    lines: {
                        show: true
                    }
                }
            },
            tooltip: {
                theme: 'dark',
                y: {
                    formatter: function (val) {
                        return val + "% performance";
                    }
                }
            }
        };

        const teamsPerformanceChart = new ApexCharts(
            document.querySelector("#teams-performance-chart"),
            teamsPerformanceOptions
        );
        teamsPerformanceChart.render();

            // Animate progress circles
            function animateProgress(circleId, percentId, finalValue) {
                let progress = 0;
                let step = finalValue / 50;
                let interval = setInterval(() => {
                    if (progress >= finalValue) {
                        clearInterval(interval);
                        progress = finalValue;
                    } else {
                        progress += step;
                    }
                    document.getElementById(percentId).innerText = Math.round(progress) + "%";
                    let offset = 314 - (314 * (progress / 100));
                    document.getElementById(circleId).style.strokeDashoffset = offset;
                }, 30);
            }

            animateProgress("circle1", "percent1", @ProjectCompleted);
            animateProgress("circle2", "percent2", @IssuesResolved);
            animateProgress("circle3", "percent3", @AddedIssues);
            animateProgress("circle4", "percent4", @TeamPerformance);
        });
    </script>
    
    <!-- jsvectormap -->
    <script src="https://cdn.jsdelivr.net/npm/jsvectormap@1.5.3/dist/js/jsvectormap.min.js"
            integrity="sha256-/t1nN2956BT869E6H4V1dnt0X5pAQHPytli+1nTZm2Y="
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jsvectormap@1.5.3/dist/maps/world.js"
            integrity="sha256-XPpPaZlU8S/HWf7FZLAncLg2SAkP8ScUTII89x9D3lY="
            crossorigin="anonymous"></script>
    <!-- jsvectormap -->
    

   
    <script>
        function animateProgress(circleId, percentId, finalValue) {
            let progress = 0;
            let step = finalValue / 50; // Controls speed
            let interval = setInterval(() => {
                if (progress >= finalValue) {
                    clearInterval(interval);
                    progress = finalValue;
                } else {
                    progress += step;
                }

                // Update percentage text
                document.getElementById(percentId).innerText = Math.round(progress) + "%";

                // Calculate stroke-dashoffset
                let offset = 314 - (314 * (progress / 100)); // 314 is full circle
                document.getElementById(circleId).style.strokeDashoffset = offset;

            }, 30); // Adjust speed
        }

        // Start animations on page load
        window.onload = function () {
            animateProgress("circle1", "percent1", @ProjectCompleted);
            animateProgress("circle2", "percent2", @IssuesResolved);
            animateProgress("circle3", "percent3", @AddedIssues);
            animateProgress("circle4", "percent4", @TeamPerformance);
        };
    </script>

    <!-- Bootstrap JS (for collapse functionality) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
