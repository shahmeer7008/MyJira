
@{
    Layout = null;
}
@{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>View Issue</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/dashboard.css" />
        <style>
            body {
                display: flex;
                background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
                background-size: cover;
                background-position: center;
                height: 100vh;
                margin: 0;
            }
         .content{
             margin-left:250px;
         }
            .status-badge {
                font-size: 1rem;
                padding: 5px 15px;
                border-radius: 15px;
            }
            .attachment-list {
                list-style: none;
                padding-left: 0;
            }
            .attachment-list li {
                background: #e9ecef;
                padding: 8px;
                border-radius: 5px;
                margin-bottom: 5px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .attachment-list a {
                text-decoration: none;
                color: #007bff;
            }
            .heading{
                color:white;
            }
        </style>
    </head>
    <body>
        <!-- Sidebar -->
        <div class="app-wrapper">
            @Html.Partial("_ManagerSidebar")

            <main class="app-main">

        <!-- Main Content -->
        <div class="content">
        <div class="heading">
            <h2 class="mb-4">Issue Details</h2>
            </div>
            <!-- Issue Card -->
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5>Issue #123: Bug in Login Page</h5>
                </div>
                <div class="card-body">
                    <p><strong>Description:</strong> Users cannot log in due to a server error.</p>
                    <p>
                        <strong>Status:</strong>
                        <span class="badge bg-warning text-dark status-badge">Open</span>
                    </p>
                    <p>
                        <strong>Priority:</strong>
                        <span class="badge bg-danger status-badge">High</span>
                    </p>

                    <!-- Progress Bar -->
                    <p><strong>Progress:</strong></p>
                    <div class="progress mb-3">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" role="progressbar" style="width: 25%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">25%</div>
                    </div>

                    <!-- Table for Metadata -->
                    <table class="table table-bordered">
                        <tr>
                            <th>Assigned To</th>
                            <td>John Doe</td>
                        </tr>
                        <tr>
                            <th>Created On</th>
                            <td>March 25, 2025</td>
                        </tr>
                        <tr>
                            <th>Last Updated</th>
                            <td>March 26, 2025</td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Comments Section -->
            <div class="card mt-4 shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5>Comments</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>Jane Smith</strong> <span class="text-muted">- March 26, 2025</span>
                        <p>We have identified the issue and are working on a fix.</p>
                        <ul class="attachment-list">
                            <li>📎 <a href="#">error_log.txt</a></li>
                        </ul>
                    </div>
                    <div class="mb-3">
                        <strong>John Doe</strong> <span class="text-muted">- March 26, 2025</span>
                        <p>Let me know if you need more details from the server logs.</p>
                        <ul class="attachment-list">
                            <li>📎 <a href="#">screenshot.png</a></li>
                            <li>📎 <a href="#">debug_report.pdf</a></li>
                        </ul>
                    </div>

                    <!-- Add Comment Section -->
                    <form>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Add a Comment:</label>
                            <textarea class="form-control" id="comment" rows="3" placeholder="Write your comment..."></textarea>
                        </div>

                        <!-- File Upload -->
                        <div class="mb-3">
                            <label for="attachment" class="form-label">Attach Files:</label>
                            <input type="file" class="form-control" id="attachment" multiple>
                        </div>

                        <button type="submit" class="btn btn-primary">Submit Comment</button>
                    </form>
                </div>
            </div>
        </div>
        </main>
        </div>
        <script>
            // JavaScript to display selected file names below the file input
            document.getElementById("attachment").addEventListener("change", function() {
                let fileList = document.getElementById("attachment").files;
                let fileNames = [];
                for (let i = 0; i < fileList.length; i++) {
                    fileNames.push("📎 " + fileList[i].name);
                }
                if (fileNames.length > 0) {
                    alert("Selected Attachments:\n" + fileNames.join("\n"));
                }
            });
        </script>

    </body>
    </html>

}
