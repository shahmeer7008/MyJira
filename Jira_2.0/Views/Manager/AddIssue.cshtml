
@{
    Layout = null;
}

@{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Add New Issue</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/dashboard.css" />
        <style>
            body {
                display: flex;
                background-color: #f8f9fa;
            }

            
            .form-label {
                font-weight: bold;
            }
        </style>
    </head>
    <body>
        <!-- Sidebar -->
       

            <div class="app-wrapper">
            @Html.Partial("_ManagerSidebar")

            <main class="app-main">


        <!-- Main Content -->
        <div class="content">
           

            <!-- Issue Form -->
            <div class="card shadow-sm" style="width:1000px">
                <div class="card-header bg-primary text-white">
                    <h5>New Issue</h5>
                </div>
                <div class="card-body">
                            <form method="post" action="AddIssue">
                                <div class="mb-3">
                                    <label for="Projid" class="form-label">Project ID</label>
                                    <input type="text" class="form-control" id="projid" name="IssueData.ProjectID" placeholder="Enter ProjectID" required>
                                </div>
                                <!-- Issue Title -->
                                <div class="mb-3">
                                    <label for="title" class="form-label">Issue Title</label>
                                    <input type="text" class="form-control" id="title" name="IssueData.Title" placeholder="Enter issue title" required>
                                </div>

                                <!-- Description -->
                                <div class="mb-3">
                                    <label for="description" class="form-label">Description</label>
                                    <textarea class="form-control" id="description" rows="4" name="IssueData.Description" placeholder="Describe the issue in detail" required></textarea>
                                </div>

                                <!-- Type Dropdown -->
                                <div class="mb-3">
                                    <label for="type" class="form-label">Type</label>
                                    <select class="form-select" id="type" name="IssueData.Type">
                                        <option value="Bug" selected>Bug</option>
                                        <option value="Feature">Feature</option>
                                        <option value="Improvement">Improvement</option>
                                    </select>
                                </div>

                                <!-- Status Dropdown -->
                                <div class="mb-3">
                                    <label for="status" class="form-label">Status</label>
                                    <select class="form-select" id="status" name="IssueData.Status">
                                        <option value="Assigned" selected>Assigned</option>
                                        <option value="In Progress">In Progress</option>
                                        <option value="Resolved">Resolved</option>
                                    </select>
                                </div>

                                <!-- Priority Dropdown -->
                                <div class="mb-3">
                                    <label for="priority" class="form-label">Priority</label>
                                    <select class="form-select" id="priority" name="IssueData.Priority">
                                        <option value="Low">Low</option>
                                        <option value="Medium">Medium</option>
                                        <option value="High">High</option>
                                        <option value="Critical">Critical</option>
                                    </select>
                                </div>

                                <!-- Assigned To -->
                                <div class="mb-3">
                                    <label for="assignedTo" class="form-label">Assigned To</label>
                                    <input type="text" class="form-control" id="assignedTo" name="IssueData.Assigned" placeholder="Enter assignee name" required>
                                </div>

                                <!-- Buttons -->
                                <button type="submit" class="btn btn-success">Create Issue</button>
                                <a href="@Url.Action("AdminDashboard", "Admin")" class="btn btn-secondary">Cancel</a>
                            </form>

                </div>
            </div>
        </div>
        </main>
        </div>
        

    </body>
    </html>

}
