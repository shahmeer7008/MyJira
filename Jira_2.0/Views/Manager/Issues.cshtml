@model List<IssueModelWrapper>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Jira 2.0 - Manage Issues</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/dashboard.css" />
    <style>
        /* Sidebar Styling */
        body {
            display: flex;
            background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
            background-size: cover;
            background-position: center;
            height: 100vh;
            margin: 0;
        }
        .content{
            color:white;
            padding:20px;
        }
        .progress {
            height: 8px;
        }

        .status-resolved {
            background-color: #28a745;
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 14px;
        }

        .status-assigned {
            background-color: #ffc107;
            color: black;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 14px;
        }

        .card {
            color: white;
            background-color: yellow;
        }

        card-body {
            color: white !important; /* Make all text white */
            background-color: yellow !important;
        }

        .card-body th,
        .card-body td,
        .card-body small,
        .card-body strong {
            color: white !important; /* Ensure all text is white */
        }

        .card-body .btn {
            color: white !important; /* Make button text white */
            border-color: white !important; /* Make button borders white */
        }


        .card-body .status-success {
            color: white !important; /* Ensure status text is white */
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="app-wrapper">
        @Html.Partial("_ManagerSidebar")

        <main class="app-main">

    <!-- Main Content -->
    <div class="content">
        <h2 class="fw-bold">Manage Issues</h2>

        <div class="card">
            <div class="card-header">
                <h4>Issue List</h4>
            </div>
            <div class="card-body">
                <table class="table table-striped align-middle table-dark">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Issue Title</th>
                            <th>Issue Type</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Assigned / Resolved By</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Issue Row 1 - Resolved -->
                                @foreach (var wrapper in Model)
                                {
                                    var issue = wrapper.IssueData;
                                    <tr>
                                        <td>@wrapper.IssueID</td>
                                        <td>@issue.Title</td>
                                        <td>
                                            @if (issue.Type == "Bug")
                                            {
                                                <span class="type-bug">Bug</span>
                                            }
                                            else if (issue.Type == "Feature")
                                            {
                                                <span class="type-feature">Feature</span>
                                            }
                                            else if (issue.Type == "Improvement")
                                            {
                                                <span class="type-improvement">Improvement</span>
                                            }
                                        
                                        </td>
                                        <td>@issue.Priority</td>
                                        <td>
                                            @if (issue.Status == "Resolved")
                                            {
                                                <span class="status-resolved">Resolved</span>
                                            }
                                            else if (issue.Status == "Assigned")
                                            {
                                                <span class="status-assigned">Assigned</span>
                                            }
                                            else
                                            {
                                                <span>@issue.Status</span>
                                            }
                                        </td>
                                        <td>
                                            @if (issue.Status == "Resolved")
                                            {
                                                <span>Resolved by: @issue.Assigned</span>
                                            }
                                            else 
                                            {
                                                <span>Assigned to: @issue.Assigned</span>
                                            }
                                        </td>
                                       
                                        <td>
                                            <button class="btn btn-primary btn-sm" onclick="View(@wrapper.IssueID)">
                                                <i class="bi bi-eye"></i> View
                                            </button>
                                            <button class="btn btn-info btn-sm" onclick="editIssue(@wrapper.IssueID)">
                                                <i class="bi bi-pencil"></i> Edit
                                            </button>
                                            <button class="btn btn-danger btn-sm" onclick="deleteIssue(@wrapper.IssueID)">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </td>
                                    </tr>
                                }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
    </main>
    </div>
    <!-- Bootstrap JS -->
   
    <script>
        function editIssue(issueId) {
            window.location.href = '/Manager/EditIssue/' + issueId;
        }
    </script>
    <script>
        function View(Id) {
            window.location.href = '/Manager/viewIssue/' + Id;
        }

    </script>
        <script>
            function deleteIssue(id) {
                if (confirm('Are you sure you want to delete this issue?')) {
                window.location.href = '/Manager/DeleteIssue/' + id;
                }
            }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
