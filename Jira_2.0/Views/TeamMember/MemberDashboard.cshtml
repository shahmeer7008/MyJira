    <style>
        /* General Card Styling */
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            overflow-x: hidden;
            background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
            background-attachment: fixed;
            background-size: cover;
            background-position: center;
        }
        .small-box {
            text-align: center;
            padding: 20px;
            border-radius: 10px;
            color: white;
        }

        /* Centered SVG Circle */
        .progress-container {
            position: relative;
            width: 120px;
            height: 120px;
            margin: 0 auto;
        }

        /* SVG Styling */
        .progress-svg {
            transform: rotate(-90deg); /* Rotates so progress starts from top */
        }

        /* Background Circle */
        .circle-bg {
            fill: none;
            stroke: rgba(255, 255, 255, 0.2); /* Light background stroke */
            stroke-width: 10;
        }

        /* Progress Bar Stroke */
        .circle-progress {
            fill: none;
            stroke: white; /* White progress stroke */
            stroke-width: 10;
            stroke-linecap: round;
            stroke-dasharray: 314; /* Full circle circumference (2 * π * 50) */
            stroke-dashoffset: 314; /* Initially hidden */
            transition: stroke-dashoffset 1.5s ease-in-out;
        }

        /* Percentage Text */
        .progress-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-weight: bold;
            font-size: 22px;
            color: white;
        }


        .metrics-carousel {
            margin: 0 auto 20px auto;
            width: 100%;
            height: 300px;
            overflow: hidden;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

            .metrics-carousel .carousel-item img {
                width: 100%;
                height: 300px;
                object-fit: cover;
                object-position: center;
            }

        .carousel-caption {
            background-color: rgba(0, 0, 0, 0.6);
            border-radius: 5px;
            padding: 10px 15px;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: 80%;
            text-align: center;
        }

        .carousel-control-prev,
        .carousel-control-next {
            width: 5%;
            background-color: rgba(0, 0, 0, 0.3);
            border-radius: 5px;
        }

        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            width: 2rem;
            height: 2rem;
        }

        .card {
            margin-bottom: 20px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        .card-header {
            padding: 15px;
            background-color: #f8f9fa;
            border-bottom: 1px solid #eee;
        }

        .card-body {
            padding: 15px;
            position: relative;
        }

        .row {
            display: flex;
            flex-wrap: wrap;
            margin-right: -15px;
            margin-left: -15px;
        }

        .col-lg-7 {
            flex: 0 0 58.333333%;
            max-width: 58.333333%;
            padding: 15px;
        }

        .col-lg-5 {
            flex: 0 0 41.666667%;
            max-width: 41.666667%;
            padding: 15px;
        }

        canvas {
            width: 100% !important;
            height: 300px !important;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
    <body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
        <!--begin::App Wrapper-->
        <div class="app-wrapper" style="color:white">
        <div class="d-flex justify-content-center"> <h3 class="mb-0 text-center">Team Member Dashboard</h3></div>

            <!--begin::Header-->
            <!--end::Header-->
            <!--begin::Sidebar-->
           @Html.Partial("_MemberSidebar")
            <!--end::Sidebar-->
            <!--begin::App Main-->
            <main class="app-main">
                <!--begin::App Content Header-->
                <div class="app-content-header mb-3">
                    <!--begin::Container-->
    <div class="container mt-4">
        


                    <div id="metricsCarousel" class="carousel slide metrics-carousel" data-bs-ride="carousel"
                         data-bs-interval="3000">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img src="https://images.unsplash.com/photo-1579389083078-4e7018379f7e?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80"
                                     class="d-block w-100" alt="Team Collaboration">
                                <div class="carousel-caption">
                                    <h5>Team Collaboration</h5>
