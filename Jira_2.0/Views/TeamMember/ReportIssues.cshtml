
@{
    Layout = null;
}
@{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Report Issues</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/dashboard.css" />
        <style>
            body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
                overflow-x: hidden;
                background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
                background-attachment: fixed;
                background-size: cover;
                background-position: center;
                display: flex;
            }
            
            .content {
                margin-left: 150px;
               
            }

            .wrapper {
                display: flex;
                width: 100%;
                min-height: 100vh;
            }


            .content {
                flex: 1;
                margin-left: 50px; /* Same as sidebar width */
                color: white;
                min-height: 100vh;
            }

            .card {
                border-radius: 10px;
                overflow: hidden;
                border: none;
            }

            .card-header {
                border-radius: 10px 10px 0 0;
                font-weight: bold;
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            }

            /* Table Styling */
            .table {
                color: white;
            }

            .table-hover tbody tr:hover {
                cursor: pointer;
            }



            .priority-high {
                background-color: rgba(220, 53, 69, 0.2) !important;
                color: #ff6b6b !important;
                font-weight: bold;
            }

            .priority-medium {
                background-color: rgba(255, 193, 7, 0.2) !important;
                color: #ffe66d !important;
                font-weight: bold;
            }

            .priority-low {
                background-color: rgba(40, 167, 69, 0.2) !important;
                color: #6bff8f !important;
                font-weight: bold;
            }

        </style>
    </head>
    <body>

        <!-- Sidebar -->
        <div class="wrapper">
            @Html.Partial("_MemberSidebar")

            <!-- Main Content -->
            <main class="content">

        <!-- Main Content -->
        <div class="content">
            <div class="container mt-4">
                <div class="card shadow-lg">
                    <div class="card-header bg-primary text-white">
                        <h3>📢 Report an Issue to Manager</h3>
                    </div>
                    <div class="card-body" style="color:white;background-color:cornflowerblue">
                        <form>
                            <div class="mb-3">
                                <label for="title" class="form-label">Issue Title</label>
                                <input type="text" class="form-control" id="title" placeholder="Enter issue title" required>
                            </div>
                            <div class="mb-3">
                                <label for="description" class="form-label">Description</label>
                                <textarea class="form-control" id="description" rows="4" placeholder="Describe the issue..." required></textarea>
                            </div>
                            <div class="mb-3">
                                <label for="priority" class="form-label">Priority</label>
                                <select class="form-select" id="priority">
                                    <option value="High">🔥 High</option>
                                    <option value="Medium">⚡ Medium</option>
                                    <option value="Low">✅ Low</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-success w-100">Submit Issue</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        </main>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
    </html>

}
