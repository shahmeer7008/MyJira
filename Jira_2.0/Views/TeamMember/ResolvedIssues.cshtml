@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resolved Issues</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/dashboard.css" />
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            overflow-x: hidden;
            background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
            background-attachment: fixed;
            background-size: cover;
            background-position: center;
            display: flex;
        }

        .wrapper {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        
        .content {
            flex: 1;
            margin-left: 50px; /* Same as sidebar width */
            color: white;
           
            
            min-height: 100vh;
        }

        .card {
            border-radius: 10px;
            overflow: hidden;
           
            border: none;
        }

        .card-header {
            border-radius: 10px 10px 0 0;
            font-weight: bold;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Table Styling */
        .table {
            color: white;
            
        }

        .table-hover tbody tr:hover {
            
            cursor: pointer;
        }

        

        .priority-high {
            background-color: rgba(220, 53, 69, 0.2) !important;
            color: #ff6b6b !important;
            font-weight: bold;
        }

        .priority-medium {
            background-color: rgba(255, 193, 7, 0.2) !important;
            color: #ffe66d !important;
            font-weight: bold;
        }

        .priority-low {
            background-color: rgba(40, 167, 69, 0.2) !important;
            color: #6bff8f !important;
            font-weight: bold;
        }

        /* Responsive adjustments */
        
            
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="wrapper">
        @Html.Partial("_MemberSidebar")
       
        <!-- Main Content -->
        <main class="content">
            <div class="container">
                <div class="card ">
                    <div class="card-header bg-success text-white text-center">
                        <h3 class="mb-0">✅ Resolved Issues</h3>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover text-center">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Title</th>
                                        <th>Resolved By</th>
                                        <th>Priority</th>
                                        <th>Date Resolved</th>
                                    </tr>
                                </thead>
                                <tbody class="table-dark">
                                    @foreach (var issue in Model)
                                    {
                                        var priorityClass = issue.Priority switch
                                        {
                                            "High" => "priority-high",
                                            "Medium" => "priority-medium",
                                            "Low" => "priority-low",
                                            _ => ""
                                        };
                                        <tr class="@priorityClass">
                                            <td>@issue.IssueID</td>
                                            <td>@issue.Title</td>
                                            <td>@issue.ResolvedBy</td>
                                            <td>
                                                @if (issue.Priority == "High")
                                                {
                                                    <span>🔥 High</span>
                                                }
                                                else if (issue.Priority == "Medium")
                                                {
                                                    <span>⚡ Medium</span>
                                                }
                                                else
                                                {
                                                    <span>✅ Low</span>
                                                }
                                            </td>
                                            <td>@issue.DateResolved</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>