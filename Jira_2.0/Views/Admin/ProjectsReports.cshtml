
@{
    Layout = null;
}

@{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Projects Reports</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
        <link rel="stylesheet" href="/css/dashboard.css" />
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <style>
           

            body {
                background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
                background-size: cover;
                background-position: center;
                height: 100vh;
                margin: 0;
            }

            .content {
                color: white;
                margin-top: 30px;
            }

            .input {
                width: 450px;
                margin-left: 200px;
                margin-top: 10px;
                padding-top: 20px;
            }

            .btndiv {
                margin-left: 270px;
            }

                 
            .heading {
                margin-left: 300px;
            }

            .form-label {
                font-weight: bold;
            }

            .chart-container {
                width: 50%;
                height: 300px;
            }
        </style>
    </head>
    <body>

        <!-- Sidebar -->
        <div class="app-wrapper">
            @Html.Partial("_sidebar")
            <main>

        <!-- Content Area -->
        <div class="content ">
        <div class="heading">
            <h2>Projects Reports</h2>
        </div>
            <form>
                <div class="mb-3 input">
                    
                    <input type="text" id="projectid"class="form-control" placeholder="Enter Project Id">
                </div>
                        <div class="btndiv d-flex gap-5">
                <button type="submit" id="reportForm"class="btn btn-primary">Generate Report</button>
                
                <button type="submit" id="pdf"class="btn btn-primary">Generate PDF</button>
                </div>

            </form>

                <div id="reportSection" class="mt-4" style="display: none;">
                    <!-- Project Summary -->
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-info text-white">
                            <h5>Project Overview</h5>
                        </div>
                        <div class="card-body" style="color:white; background-color:darkorchid">
                            <p><strong>Project Name:</strong> <span id="projectName">Project Alpha</span></p>
                            <p><strong>Total Issues:</strong> <span id="totalIssues">50</span></p>
                            <p><strong>Resolved Issues:</strong> <span id="resolvedIssues">40</span></p>
                            <p><strong>Pending Issues:</strong> <span id="pendingIssues">10</span></p>
                        </div>
                    </div>

                    <!-- Progress Bar -->
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-success text-white">
                            <h5>Project Progress</h5>
                        </div>
                        <div class="card-body" style="color:white ;background-color:darkolivegreen">
                            <div class="progress" style="height: 30px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" id="progressBar" style="width: 80%;">80%</div>
                            </div>
                        </div>
                    </div>

                    <!-- Project Status Graph -->
                    <div class="card shadow-sm">
                        <div class="card-header bg-warning" style="color:white;background-color:fuchsia">
                            <h5>Issue Breakdown</h5>
                        </div>
                        <div class="card-body" style="color:white;background-color:darkblue">
                            <canvas id="projectChart" class="chart-container"></canvas>
                        </div>
                    </div>
                </div>

        </div>
        </main>
        </div>

        <script>
            // Store chart instance globally
            let projectChart = null;

            document.getElementById("reportForm").addEventListener("click", function (event) {
                event.preventDefault();

                // Show the report section
                document.getElementById("reportSection").style.display = "block";

                // Get the input value (make sure your input has id="projectId")
                let projectId = document.querySelector(".form-control").value;

                // Example data
                let projectData = {
                    "P101": { name: "Project Alpha", total: 50, resolved: 40, pending: 10, progress: 80 },
                    "P102": { name: "Project Beta", total: 70, resolved: 50, pending: 20, progress: 72 },
                    "P103": { name: "Project Gamma", total: 90, resolved: 60, pending: 30, progress: 66 }
                };

                // Use default data if no match
                let data = projectData[projectId] || projectData["P101"];

                // Update the text elements
                document.getElementById("projectName").innerText = data.name;
                document.getElementById("totalIssues").innerText = data.total;
                document.getElementById("resolvedIssues").innerText = data.resolved;
                document.getElementById("pendingIssues").innerText = data.pending;

                // Update Progress Bar
                let progressBar = document.getElementById("progressBar");
                progressBar.style.width = data.progress + "%";
                progressBar.innerText = data.progress + "%";

                // Update Chart - destroy old one first if exists
                if (projectChart) {
                    projectChart.destroy();
                }
                renderChart(data);
            });

            function renderChart(data) {
                let ctx = document.getElementById("projectChart").getContext("2d");

                projectChart = new Chart(ctx, {
                    type: 'pie',
                    data: {
                        labels: ["Resolved Issues", "Pending Issues"],
                        datasets: [{
                            data: [data.resolved, data.pending],
                            backgroundColor: [
                                'rgba(54, 162, 235, 0.7)',
                                'rgba(255, 99, 132, 0.7)'
                            ],
                            borderColor: [
                                'rgba(54, 162, 235, 1)',
                                'rgba(255, 99, 132, 1)'
                            ],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: {
                                    color: 'white',
                                    font: {
                                        size: 14
                                    }
                                }
                            }
                        }
                    }
                });
            }
        </script>
        
    </body>
    </html>

}
