@model Jira_2._0.Models.ProjectModelWrapper
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Project</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/dashboard.css" />
</head>
<body>
    <div class="app-wrapper">
        @Html.Partial("_sidebar")
        <main>
            <div class="content">
                <div class="card mr-5">
                    <div class="card-header bg-primary text-white">
                        Create Project
                    </div>
                    <div class="card-body">
                        <form asp-action="CreateProject" method="post">
                            <div class="mb-3">
                                <label asp-for="ProjectData.ProjectName" class="form-label">Project Name</label>
                                <input asp-for="ProjectData.ProjectName" class="form-control" required>
                                <span asp-validation-for="ProjectData.ProjectName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ProjectData.Description" class="form-label">Project Description</label>
                                <textarea asp-for="ProjectData.Description" class="form-control" rows="3" required></textarea>
                                <span asp-validation-for="ProjectData.Description" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ProjectData.Status" class="form-label">Status</label>
                                <select asp-for="ProjectData.Status" class="form-select" required>
                                    <option value="">Select one</option>
                                    <option value="In Progress">In Progress</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Pending">Pending</option>
                                </select>
                                <span asp-validation-for="ProjectData.Status" class="text-danger"></span>
                            </div>
                            
                            <div class="mb-3">
                                <label asp-for="ProjectData.Client" class="form-label">Client Company</label>
                                <input asp-for="ProjectData.Client" class="form-control" required>
                                <span asp-validation-for="ProjectData.Client" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ProjectData.Leader" class="form-label">Project Leader</label>
                                <input asp-for="ProjectData.Leader" class="form-control" required>
                                <span asp-validation-for="ProjectData.Leader" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ProjectData.Team" class="form-label">Project Team</label>
                                <input asp-for="ProjectData.Team" class="form-control" required>
                                <span asp-validation-for="ProjectData.Team" class="text-danger"></span>
                            </div>

                            <button type="button" class="btn btn-secondary" onclick="window.location.href='/Admin/Projects'">Cancel</button>
                            <button type="submit" class="btn btn-success float-end">Create Project</button>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>