@model List<Jira_2._0.Models.CustomisedUserModel.ApplicationUser>
@{
    Layout = null;
}
@{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Users Record</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
        <link rel="stylesheet" href="/css/dashboard.css" />
        <style>
            body {
                background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
                background-size: cover;
                background-position: center;
                height: 100vh;
                margin: 0;
                padding:0;
            }

            .content {
                color: white;
            }

            .heading {
                margin-left: 300px;
            }

            .table-custom th {
                background-color: #292b3a;
                color: #ffffff;
                border: none;
            }

            .table-custom td {
                background-color: #202230;
                border: none;
                color: #ddd;
            }

            .table-custom tr:hover td {
                background-color: #2c2f3e;
            }
        </style>
    </head>
    <body>

        <!-- Sidebar -->
        <div class="app-wrapper">
            @Html.Partial("_sidebar")
            <main>

                <!-- Content Area -->
                <div class="content">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center bg-primary p-2">
                            <h4 class="text-white">Users Record</h4>
                        </div>

                        <div class="card-body table-responsive p-0">
                            <table class="table table-custom mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model)
                                    {
                                        <tr>
                                            <td>@user.Name</td>
                                            <td>@user.Email</td>
                                            <td>@user.RequestedClaim</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </main>
        </div>
    </body>
    </html>
}
