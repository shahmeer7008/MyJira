@model Jira_2._0.Models.ProjectModelWrapper
@{
    Layout = null;
}

@{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Edit Project</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
        <link rel="stylesheet" href="/css/dashboard.css" />
        
    </head>
    <body>

        <!-- Sidebar with Correct Icons -->
        <div class="app-wrapper">
        @Html.Partial("_sidebar")
        <main>
        <!-- Content Area -->
       <div class="content">
    <div class="card" style="width:100vw">
        <div class="card-header bg-primary text-white">
            Edit Project
        </div>
        <div class="card-body">
                            <form method="post" asp-action="EditProject">
                                <input type="hidden" asp-for="ProjectID" />

                                <div class="mb-3">
                                    <label asp-for="ProjectData.ProjectName" class="form-label"></label>
                                    <input asp-for="ProjectData.ProjectName" class="form-control" />
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ProjectData.Description" class="form-label"></label>
                                    <textarea asp-for="ProjectData.Description" class="form-control" rows="3"></textarea>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ProjectData.Status" class="form-label"></label>
                                    <select asp-for="ProjectData.Status" class="form-select">
                                        <option value="In Progress">In Progress</option>
                                        <option value="Completed">Completed</option>
                                        <option value="Pending">Pending</option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ProjectData.Client" class="form-label"></label>
                                    <input asp-for="ProjectData.Client" class="form-control" />
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ProjectData.Leader" class="form-label"></label>
                                    <input asp-for="ProjectData.Leader" class="form-control" />
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ProjectData.Team" class="form-label"></label>
                                    <input asp-for="ProjectData.Team" class="form-control" />
                                </div>

                                <button type="submit" class="btn btn-success mt-3">Update Project</button>
                                <button type="button" class="btn btn-danger mt-3" onclick="window.location.href='/Admin/Projects'">Cancel</button>
                            </form>

        </div>
    </div>
</div>

        </main>
        </div>
    </body>
    </html>

}
