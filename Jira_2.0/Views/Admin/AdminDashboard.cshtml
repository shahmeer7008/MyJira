    <script>
        // Project Progress Chart (Bar Chart)
        const progressOptions = {
            series: [
                {
                    name: 'Completed',
                    data: [45, 75, 60, 80, 90, 50, 70]
                },
                {
                    name: 'In Progress',
                    data: [30, 15, 30, 10, 5, 30, 20]
                },
                {
                    name: 'Not Started',
                    data: [25, 10, 10, 10, 5, 20, 10]
                }
            ],
            chart: {
                type: 'bar',
                height: 350,
                stacked: true,
                stackType: '100%',
                toolbar: {
                    show: false
                }
            },
            plotOptions: {
                bar: {
                    horizontal: true,
                },
            },
            colors: ['#20c997', '#fd7e14', '#6c757d'],
            xaxis: {
                categories: ['Website Redesign', 'Mobile App', 'CRM System', 'Marketing Campaign', 'Product Launch', 'HR Portal', 'Data Migration'],
                title: {
                    text: 'Progress Percentage'
                }
            },
            yaxis: {
                title: {
                    text: 'Projects'
                }
            },
            tooltip: {
                y: {
                    formatter: function (val) {
                        return val + "%"
                    }
                }
            },
            legend: {
                position: 'top',
                horizontalAlign: 'center'
            }
        };

        const progressChart = new ApexCharts(
            document.querySelector('#project-progress-chart'),
            progressOptions
        );
        progressChart.render();

        // Team Contributions Chart (Pie Chart)
        const contributionsOptions = {
            series: [25, 20, 18, 15, 12, 10],
            chart: {
                type: 'pie',
                height: 350
            },
            labels: ['Alex Johnson', 'Sarah Williams', 'Michael Chen', 'Emma Davis', 'David Kim', 'Other Team'],
            colors: ['#0d6efd', '#6610f2', '#6f42c1', '#d63384', '#fd7e14', '#20c997'],
            responsive: [{
                breakpoint: 480,
                options: {
                    chart: {
                        width: 200
                    },
                    legend: {
                        position: 'bottom'
                    }
                }
            }],
            tooltip: {
                y: {
                    formatter: function (val) {
                        return val + "%"
                    }
                }
            }
        };

        const contributionsChart = new ApexCharts(
            document.querySelector('#contributions-chart'),
            contributionsOptions
        );
        contributionsChart.render();
    </script>



    <script>
