@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kanban Notifications</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <link rel="stylesheet" href="/css/dashboard.css" />

    <style>
        body {
            background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            height: 100vh;
            margin: 0;
            background-color: #f8f9fa;
        }

        .notification-card {
            display: flex;
            align-items: center;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            background: white;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            background-color: crimson;
        }

            .notification-card:hover {
                transform: scale(1.02);
            }

        .icon {
            font-size: 1.8rem;
            margin-right: 15px;
        }

        .read {
            opacity: 0.6;
        }

        .notification-badge {
            background: red;
            color: white;
            font-size: 12px;
            padding: 4px 8px;
            border-radius: 50%;
            position: relative;
            top: -5px;
            left: 5px;
        }
    </style>
</head>
<body>
    <div class="app-wrapper">
        @Html.Partial("_sidebar")
        <main class="container mt-4">
            @{
                var requestedClaim = User.FindFirst("UserType")?.Value;

                Console.WriteLine("ksnnasddnsddasdd");
                Console.WriteLine(requestedClaim);
                var isVerified = User.FindFirst("IsClaimVerified")?.Value == "1";
                var isRejected = User.FindFirst("IsRejected")?.Value == "1";

                isVerified = isVerified || true;
                isRejected = isRejected || false;

                var isRegistered = isVerified && !isRejected;
                var userRole = requestedClaim ?? "Unknown";
            }
           <!-- <div class="alert alert-info">
                <h5>User Claims</h5>
                 @foreach (var claim in User.Claims)
                 {
                     <p><strong>@claim.Type</strong>: @claim.Value</p>
                 }
            </div>-->

            @if (!isRegistered)
            {
                <div class="alert alert-danger">
                    You are not a verified user or your request has been rejected. Please contact the administrator.
                </div>
            }
            else
            {
                <div class="card p-4 mb-4 bg-light shadow-sm rounded-4" style="max-width: 600px;">
                    <h5 class="mb-3">Send Notification</h5>
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-primary text-white"><i class="bi bi-person"></i></span>
                        <input type="text" id="targetId" class="form-control" placeholder="Enter recipient ID" />
                    </div>
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-success text-white"><i class="bi bi-chat-dots"></i></span>
                        <input type="text" id="messageText" class="form-control" placeholder="Enter your message" />
                    </div>
                    <button class="btn btn-lg btn-primary w-100" id="sendMessageButton">Send Message</button>
                </div>

                <h4>Notifications</h4>
                <div id="notificationsArea" class="mt-4"></div>
            }
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @if (isRegistered)
    {
        <script>
            window.userRoleFromView = "@userRole"; // Razor injects the role
        </script>
        <script src="/js/signal.js"></script> <!-- This avoids Razor tilde (~) misunderstanding -->
    }
</body>
</html>
