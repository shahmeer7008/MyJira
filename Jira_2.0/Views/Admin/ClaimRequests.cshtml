@model List<ClaimRequestViewModel>

@{
    Layout = null;
}
@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Claim Requests</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard.css" />
    <style>
        body {
            background-image: url('https://images.unsplash.com/photo-1627634777217-c864268db30c?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            height: 100vh;
            margin: 0;
        }

        .content {
            color: white;
            margin-top: 30px;
        }

        .container-box {
            margin: 40px auto;
            background-color: rgba(0,0,0,0.6);
            padding: 20px;
            border-radius: 10px;
            width: 80%;
        }

        .btn-approve, .btn-reject {
            width: 120px;
        }

        .heading {
            text-align: center;
            margin-bottom: 30px;
        }

        .table {
            width: 100%;
            margin-top: 20px;
        }

        .table-custom th {
            background-color: #292b3a;
            color: #ffffff;
            border: none;
        }

        .table-custom td {
            background-color: #202230;
            border: none;
            color: #ddd;
        }
        .btn {
            margin-right: 5px;
        }

        .alert {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="app-wrapper">
        @Html.Partial("_sidebar")
        <main>
            <div class="content">
                <div class="container-box">
                    <h2 class="heading">Pending Claim Requests</h2>

                    @if (Model != null && Model.Count > 0)
                    {


                        <table class="table  table-custom">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Email</th>
                                    <th>Requested Claim</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var request in Model)
                                {
                                    <tr>
                                        <td>@request.Username</td>
                                        <td>@request.Email</td>
                                        <td>@request.RequestedClaim</td>
                                        <td>
                                            <form asp-action="HandleClaim" method="post">
                                                <input type="hidden" name="userId" value="@request.UserId" />
                                                <input type="hidden" name="claim" value="@request.RequestedClaim" />

                                                <button type="submit" name="decision" value="approve"
                                                        class="btn btn-success">
                                                    Approve
                                                </button>

                                                <button type="submit" name="decision" value="reject"
                                                        class="btn btn-danger">
                                                    Reject
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-white text-center">No pending claim requests.</p>
                    }
                </div>
            </div>
        </main>
    </div>
</body>
</html>
